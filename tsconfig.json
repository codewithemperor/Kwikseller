{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "references": [
    { "path": "apps/api" },
    { "path": "apps/marketplace" },
    { "path": "apps/vendor" },
    { "path": "apps/admin" },
    { "path": "apps/rider" }
  ],
  "exclude": [
    "node_modules",
    "apps/api/dist",
    "apps/*/node_modules",
    "packages/*/node_modules"
  ]
}
